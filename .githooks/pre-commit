#!/usr/bin/env bash
# Pre-commit hook: run ruff + pytest on the working copy so the CI
# lint/test gates never see a dirty commit.
#
# Activate once per clone with:   git config core.hooksPath .githooks
#
# Fast path: if a required tool isn't on PATH (e.g., dev dependencies
# not installed), warn and pass — the commit proceeds and CI will
# catch the miss. A hard fail here would block users who haven't yet
# done `pip install -e .[dev]`.
#
# Opt out of the pytest leg for a single commit with:
#     SKIP_PYTEST=1 git commit …
# (useful for WIP / doc-only commits that don't merit the ~2s cost).
set -euo pipefail

# Git invokes hooks without activating any virtualenv, so reach for the
# project's .venv explicitly when it exists — otherwise fall back to
# whatever is on PATH.
repo_root="$(git rev-parse --show-toplevel)"
venv_bin="$repo_root/.venv/bin"
if [ -x "$venv_bin/ruff" ]; then
    ruff_cmd="$venv_bin/ruff"
elif command -v ruff >/dev/null 2>&1; then
    ruff_cmd="$(command -v ruff)"
else
    ruff_cmd=""
fi
if [ -x "$venv_bin/pytest" ]; then
    pytest_cmd="$venv_bin/pytest"
elif command -v pytest >/dev/null 2>&1; then
    pytest_cmd="$(command -v pytest)"
else
    pytest_cmd=""
fi

if [ -z "$ruff_cmd" ]; then
    echo "pre-commit: ruff not found; skipping lint." >&2
    echo "           install with: pip install -e .[dev]" >&2
else
    "$ruff_cmd" check .
fi

# Rust formatting gate: only when the commit stages Rust files (fmt is
# ~instant; clippy is deliberately left to CI — too slow for a hook).
# Same warn-and-pass philosophy as above when cargo isn't installed.
if git diff --cached --name-only | grep -qE '^rust/.*\.rs$'; then
    if command -v cargo >/dev/null 2>&1; then
        if ! (cd "$repo_root/rust" && cargo fmt --all --check); then
            echo "pre-commit: rustfmt drift — run: (cd rust && cargo fmt --all)" >&2
            exit 1
        fi
    else
        echo "pre-commit: cargo not found; skipping rustfmt check." >&2
    fi
fi

if [ "${SKIP_PYTEST:-0}" = "1" ]; then
    echo "pre-commit: SKIP_PYTEST=1 set; skipping pytest." >&2
    exit 0
fi

if [ -z "$pytest_cmd" ]; then
    echo "pre-commit: pytest not found; skipping tests." >&2
    echo "           install with: pip install -e .[dev]" >&2
    exit 0
fi

# -q keeps output scannable; -x fails fast on the first broken test.
"$pytest_cmd" -q -x

# Iterate-guard gate: refuse the commit when a previously-passing rule
# regressed past the iteration-policy tolerance. Skips the rescan for
# doc-only commits; bypass with SKIP_EVAL_JSS_GUARD=1.
guard_script="$repo_root/scripts/git-hooks/pre-commit-guard"
if [ -x "$guard_script" ]; then
    "$guard_script"
fi
