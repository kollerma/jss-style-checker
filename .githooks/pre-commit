#!/usr/bin/env bash
# Pre-commit hook: run ruff on the staged snapshot so the CI lint
# gate never sees a dirty commit.
#
# Activate once per clone with:   git config core.hooksPath .githooks
#
# Fast path: if ruff isn't on PATH (e.g., dev dependencies not
# installed), warn and pass — the commit proceeds and CI will catch
# the miss. A hard fail here would block users who haven't yet done
# `pip install -e .[dev]`.
set -euo pipefail

if ! command -v ruff >/dev/null 2>&1; then
    echo "pre-commit: ruff not found on PATH; skipping lint." >&2
    echo "           install with: pip install -e .[dev]" >&2
    exit 0
fi

# Only lint tracked files matching the ruff target globs — avoids
# wasting time on the CRAN tarball dump under examples/.
ruff check .
