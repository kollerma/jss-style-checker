{
  "name": "jss-style-checker",
  "displayName": "JSS Style Checker",
  "description": "Lint LaTeX/BibTeX manuscripts against the JSS style guide.",
  "version": "1.0.1",
  "publisher": "kollerma",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:latex",
    "onLanguage:tex",
    "onLanguage:rnoweb",
    "onLanguage:rmd",
    "onCommand:jss-lint.runInit",
    "onCommand:jss-lint.applyAllFixes",
    "workspaceContains:**/*.tex",
    "workspaceContains:**/*.ltx",
    "workspaceContains:**/*.Rnw",
    "workspaceContains:**/*.Rmd",
    "workspaceContains:**/*.bib"
  ],
  "contributes": {
    "configuration": {
      "title": "JSS Style Checker",
      "properties": {
        "jssStyleChecker.severityOverrides": {
          "type": "object",
          "default": {},
          "additionalProperties": {
            "type": "string",
            "enum": [
              "error",
              "warning",
              "info"
            ]
          },
          "description": "Per-rule severity override map (e.g. {\"JSS-CAP-003\": \"info\"}). Merged over any [severity_overrides] in .jss-lint.toml; per rule id, this setting wins."
        },
        "jssStyleChecker.ignoreRules": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Rule ids to suppress. Unioned with ignore_rules from .jss-lint.toml."
        },
        "jssStyleChecker.codeWidth": {
          "type": "number",
          "default": 80,
          "description": "Maximum line width for JSS-WIDTH-001."
        },
        "jssStyleChecker.runOn": {
          "type": "string",
          "enum": [
            "save",
            "change"
          ],
          "default": "change",
          "description": "When to re-lint (default: on every change)."
        }
      }
    },
    "commands": [
      {
        "command": "jss-lint.runInit",
        "title": "jss-lint: Run init",
        "category": "jss-lint"
      },
      {
        "command": "jss-lint.applyAllFixes",
        "title": "jss-lint: Apply all fixes",
        "category": "jss-lint"
      }
    ]
  },
  "scripts": {
    "build:wasm": "cd ../rust/jsslint-wasm && wasm-pack build --release --target nodejs --out-dir ../../vscode-extension/wasm",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.125.0",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kollerma/jss-style-checker"
  }
}
