title: "jss-style-checker: a style checker for Journal of Statistical Software manuscripts"
version: 1.1.0
date-released: 2026-07-19
authors:
  - family-names: Koller
    given-names: Manuel
    orcid: "https://orcid.org/0000-0002-4159-922X"
license: MIT
