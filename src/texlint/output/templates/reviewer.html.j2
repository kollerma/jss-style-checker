<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>jss-lint compliance — {{ report.journal_id }}</title>
<style>
  body { font-family: -apple-system, Segoe UI, Roboto, sans-serif; margin: 2rem; color: #222; }
  h1 { margin-top: 0; }
  table { border-collapse: collapse; width: 100%; margin-top: 0.5rem; }
  th, td { border: 1px solid #ddd; padding: 0.5rem 0.75rem; font-size: 0.95rem; }
  th { background: #f5f5f5; text-align: left; }
  .num { text-align: right; font-variant-numeric: tabular-nums; }
  .status-PASS { color: #2a7a2a; font-weight: 600; }
  .status-FAIL { color: #b00020; font-weight: 600; }
  .status-SKIPPED { color: #777; font-weight: 600; }
  .overall { font-size: 1.6rem; margin-top: 1rem; }
  .overall.none { color: #777; }
</style>
</head>
<body>
<h1>Journal compliance — {{ report.journal_id }}</h1>
<p>Tool version: <code>{{ report.tool_version }}</code></p>
<table>
  <thead>
    <tr><th>Category</th><th>Status</th><th class="num">Applied</th><th class="num">Passed</th></tr>
  </thead>
  <tbody>
  {% for c in report.categories %}
    <tr>
      <td>{{ c.title }}</td>
      <td class="status-{{ c.status.value }}">{{ c.status.value }}</td>
      <td class="num">{{ c.rules_applied }}</td>
      <td class="num">{{ c.rules_passed }}</td>
    </tr>
  {% endfor %}
  </tbody>
</table>
{% if report.compliance_percentage is none %}
<p class="overall none">Overall: n/a</p>
{% else %}
<p class="overall">Overall: <strong>{{ report.compliance_percentage }}%</strong></p>
{% endif %}
</body>
</html>
