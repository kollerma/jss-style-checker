<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>JSS conformance report — {{ summary.title }}</title>
<style>
  body { font-family: -apple-system, Segoe UI, Roboto, sans-serif; margin: 2rem; color: #222; max-width: 48rem; }
  h1 { margin-top: 0; }
  h2 { border-bottom: 1px solid #ccc; padding-bottom: 0.25rem; margin-top: 2rem; }
  ul.meta { list-style: none; padding-left: 0; }
  ul.meta li { margin: 0.15rem 0; }
  .score { font-size: 1.6rem; font-weight: 600; }
  .score.none { color: #777; font-weight: 400; font-style: italic; }
  table { border-collapse: collapse; width: 100%; margin-top: 0.5rem; }
  th, td { border: 1px solid #ddd; padding: 0.4rem 0.6rem; text-align: left; vertical-align: top; font-size: 0.95rem; }
  th { background: #f5f5f5; }
  td.num { text-align: right; font-variant-numeric: tabular-nums; }
  code, .rid { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; }
  .sev-error { color: #b00020; font-weight: 600; }
  .sev-warning { color: #b8860b; font-weight: 600; }
  .sev-info { color: #555; font-weight: 600; }
  .none { color: #888; font-style: italic; }
  footer { margin-top: 2rem; padding-top: 0.5rem; border-top: 1px solid #ccc; color: #555; font-size: 0.9rem; }
</style>
</head>
<body>
<h1>JSS conformance report — {{ summary.title }}</h1>
<ul class="meta">
  <li><strong>Author:</strong> {{ summary.author }}</li>
  <li><strong>Files:</strong> {{ summary.file_count }}</li>
  <li><strong>Run date:</strong> {{ summary.run_date }}</li>
</ul>

<h2>Conformance score:
  {% if summary.score_percent is none %}
    <span class="score none">n/a</span>
  {% else %}
    <span class="score">{{ summary.score_percent }} %</span>
  {% endif %}
</h2>
<p>({{ summary.rules_passing }} of {{ summary.rules_total_active }} rules pass)</p>

<h2>Severity counts</h2>
<ul>
  <li>Errors: {{ summary.error_count }}</li>
  <li>Warnings: {{ summary.warning_count }}</li>
  <li>Info: {{ summary.info_count }}</li>
</ul>

<h2>Top 5 most-violated rules</h2>
{% if summary.top_five %}
<table>
  <thead>
    <tr><th>Rule</th><th class="num">Count</th><th>Example</th></tr>
  </thead>
  <tbody>
  {% for e in summary.top_five %}
    <tr>
      <td><code class="rid">{{ e.rule_id }}</code></td>
      <td class="num">{{ e.count }}</td>
      <td><code>{{ e.example_file }}:{{ e.example_line }}</code> — {{ e.example_excerpt }}</td>
    </tr>
  {% endfor %}
  </tbody>
</table>
{% else %}
<p class="none">(none)</p>
{% endif %}

<h2>Fix me first</h2>
{% if summary.fix_me_first %}
<ol>
  {% for item in summary.fix_me_first %}
    <li><code class="rid">{{ item.rule_id }}</code>
      (<span class="sev-{{ item.severity.value }}">{{ item.severity.value }}</span>)
      — {{ item.count }}</li>
  {% endfor %}
</ol>
{% else %}
<ol>
  <li class="none">(no violations)</li>
</ol>
{% endif %}

<footer>Generated by jss-lint.</footer>
</body>
</html>
