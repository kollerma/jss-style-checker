TARGET_DIR = ./rust/target
LIBDIR = $(TARGET_DIR)/release
STATLIB = $(LIBDIR)/libjsslintr.a
PKG_LIBS = -L$(LIBDIR) -ljsslintr

all: $(SHLIB) rust_clean

.PHONY: $(STATLIB)

$(SHLIB): $(STATLIB)

# `document` (src/rust/document.rs) regenerates R/extendr-wrappers.R
# from the compiled library's own extendr metadata after every build,
# so the R wrapper signatures can never drift from the actual `#[extendr]`
# functions.
$(STATLIB):
	cargo build --lib --release --locked --manifest-path=./rust/Cargo.toml --target-dir $(TARGET_DIR)
	cargo run --bin document --release --locked --manifest-path=./rust/Cargo.toml --target-dir $(TARGET_DIR)

rust_clean: $(SHLIB)
	rm -Rf $(TARGET_DIR)

clean:
	rm -Rf $(SHLIB) $(STATLIB) $(OBJECTS) $(TARGET_DIR)
